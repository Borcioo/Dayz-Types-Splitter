<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:TypesSplitter"
        x:Class="TypesSplitter.MainWindow"
        x:DataType="local:MainViewModel"
        Title="DayZ Types Splitter"
        Width="620" Height="560"
        MinWidth="520" MinHeight="460"
        Icon="/Assets/app.ico"
        DragDrop.AllowDrop="True">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="16" RowSpacing="12">

        <!-- Input row -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" IsReadOnly="True"
                     Text="{Binding InputPath}"
                     Watermark="Drop types.xml anywhere in this window…" />
            <Button Grid.Column="1" Content="Open types.xml…" Click="OnOpenFile" />
        </Grid>

        <!-- Output row -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" IsReadOnly="True"
                     Text="{Binding OutputDirectory}"
                     Watermark="Output folder (defaults to the source folder)" />
            <Button Grid.Column="1" Content="Output folder…" Click="OnPickOutput" />
        </Grid>

        <!-- Categories -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="8">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <TextBlock Text="Categories" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <Button Content="All" FontSize="12" Padding="8,2"
                            Command="{Binding SelectAllCommand}">
                        <Button.CommandParameter><x:Boolean>True</x:Boolean></Button.CommandParameter>
                    </Button>
                    <Button Content="None" FontSize="12" Padding="8,2"
                            Command="{Binding SelectAllCommand}">
                        <Button.CommandParameter><x:Boolean>False</x:Boolean></Button.CommandParameter>
                    </Button>
                </StackPanel>
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:CategoryItem">
                                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Display}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button Content="Split" Classes="accent" MinWidth="120"
                    Command="{Binding SplitCommand}" />
            <Button Content="Copy cfgeconomycore.xml snippet"
                    Command="{Binding CopySnippetCommand}" />
        </StackPanel>

        <!-- Snippet preview -->
        <TextBox Grid.Row="4" IsReadOnly="True" MaxHeight="120"
                 FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12"
                 Text="{Binding Snippet}"
                 IsVisible="{Binding Snippet, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <!-- Status -->
        <TextBlock Grid.Row="5" Text="{Binding Status}" Opacity="0.8" TextWrapping="Wrap" />
    </Grid>
</Window>
